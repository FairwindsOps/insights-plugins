{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "minimumReleaseAge": "7 days",
  "enabledManagers": [
    "gomod",
    "dockerfile",
    "circleci",
    "custom.regex"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": ["ENV trivyVersion=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "aquasecurity/trivy",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": ["ENV polarisVersion=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "FairwindsOps/polaris",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": ["ENV plutoVersion=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "FairwindsOps/pluto",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": ["ENV helmVersion=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "helm/helm",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": ["ENV kubectlVersion=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "kubernetes/kubernetes",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": ["ENV CLOUD_SDK_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "google/cloud-sdk",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": ["ENV PG_PARTMAN_VERSION=(?<currentValue>v[\\d.]+)"],
      "depNameTemplate": "pgpartman/pg_partman",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Kind node image for rok8s-scripts kubernetes_e2e_tests (orb job parameter)",
      "fileMatch": ["(^|/)\\.circleci/config\\.yml$"],
      "matchStrings": [
        "kind_node_image:\\s*\"kindest/node:(?<currentValue>v[^@\"]+)@sha256:(?<currentDigest>[a-f0-9]+)\""
      ],
      "depNameTemplate": "kindest/node",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "golangci-lint version in CircleCI test job",
      "fileMatch": ["(^|/)\\.circleci/config\\.yml$"],
      "matchStrings": [
        "golangci/golangci-lint/v2/cmd/golangci-lint@(?<currentValue>v[0-9.]+)"
      ],
      "depNameTemplate": "golangci/golangci-lint",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "matchDepTypes": ["replace"],
      "enabled": false
    },
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "Go non-major updates"
    },
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major"],
      "groupName": "Go major updates"
    },
    {
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "Dockerfile non-major updates"
    },
    {
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["major"],
      "groupName": "Dockerfile major updates"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["**/Dockerfile"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "Dockerfile non-major updates"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["**/Dockerfile"],
      "matchUpdateTypes": ["major"],
      "groupName": "Dockerfile major updates"
    },
    {
      "matchManagers": ["circleci"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "CircleCI non-major updates"
    },
    {
      "matchManagers": ["circleci"],
      "matchUpdateTypes": ["major"],
      "groupName": "CircleCI major updates"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchFileNames": [".circleci/config.yml"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "CircleCI config (regex) non-major updates"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchFileNames": [".circleci/config.yml"],
      "matchUpdateTypes": ["major"],
      "groupName": "CircleCI config (regex) major updates"
    }
  ]
}
