# Keyless + keyed verification (public images only; no signing in this test).
export IMAGE_TRUST_MODES='cosign-keyless,cosign-key'
export IMAGE_TRUST_PUBLIC_KEY_DIR='../testdata/keys'
export IMAGE_TRUST_IGNORE_TLOG=true

# Attestations auto-append cosign-attestation-keyless when enabled or types are set:
# export IMAGE_TRUST_ATTESTATIONS_ENABLED=true
# export IMAGE_TRUST_ATTESTATION_TYPES='slsaprovenance1'

# Trust policy: Chainguard public images on cgr.dev/chainguard/* (keyless verified deployment).
# https://edu.chainguard.dev/chainguard/chainguard-images/how-to-use/verifying-chainguard-images-and-metadata-signatures-with-cosign/
export IMAGE_TRUST_TRUSTED_ISSUERS='https://token.actions.githubusercontent.com'
export IMAGE_TRUST_TRUSTED_SUBJECTS='https://github.com/chainguard-images/images/.github/workflows/release.yaml@refs/heads/main'

# Keyed verification uses Fairwinds OSS release signing key (cosign-p256.pub).
# https://github.com/FairwindsOps/polaris/releases — keyed-verified runs polaris:v10.2.0.

# Only scan smoke workloads (avoids kind/kube-system noise in local reports).
export NAMESPACE_ALLOWLIST='image-trust-smoke'

export MAX_CONCURRENT_SCANS=3
export IMAGE_VERIFY_TIMEOUT_SECONDS=300

# Digest resolution (default true); merge workload pull secrets when true:
# export IMAGE_TRUST_RESOLVE_DIGESTS=true
# export IMAGE_TRUST_USE_IMAGE_PULL_SECRETS=true

# Private registry (optional):
# export REGISTRY_PASSWORD_FILE=/etc/registry/password
# export REGISTRY_DOCKER_CONFIG_PATH=/etc/docker/config.json
